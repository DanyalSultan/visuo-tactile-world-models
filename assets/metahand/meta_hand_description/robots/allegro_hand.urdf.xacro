<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="allegro_hand_left">
<!-- Adapted from https://github.com/simlabrobotics/allegro_hand_ros/blob/master/allegro_hand_description/allegro_hand_description_left.xacro -->

<xacro:arg name="joint_postfix" default=""/>
<xacro:property name="DEG2RAD" value="0.01745329251" />
<xacro:property name="fingertip_enum_base" value="base" />
<xacro:property name="fingertip_enum_digit" value="digitv1" />
<xacro:property name="fingertip_enum_digit360" value="digit360" />

<!-- ======================== FINGER PARAMS ======================== -->

<xacro:property name="links_x" value="0.0196" />
<xacro:property name="links_y" value="0.0275" />

<xacro:property name="link0_z" value="0.0164" />
<xacro:property name="link1_z" value="0.0540" />
<xacro:property name="link2_z" value="0.0384" />

<!-- full height from joint to tip. when used,
the radius of the finger tip sphere will be subtracted
and one fixed link will be added for the tip. -->
<xacro:property name="link3_z" value="0.0387" />
<xacro:property name="fingerTip_r" value="0.0120" />

<!-- ========================= THUMB PARAMS ========================= -->

<xacro:property name="link0_t_x" value="0.0358" />
<xacro:property name="link0_t_y" value="0.0340" />
<xacro:property name="link0_t_z" value="0.0455" />

<xacro:property name="link1_t_z" value="0.0177" />
<xacro:property name="link2_t_z" value="0.0514" />
<xacro:property name="link3_t_z" value="0.0543" />


<!-- ========================= LIMITS ========================= -->

<xacro:property name="joint_safety_margin" value="0.1" />
<xacro:property name="limit_0_up" value="0.57" />
<xacro:property name="limit_0_low" value="-0.57" />
<xacro:property name="limit_1_up" value="1.19" />
<xacro:property name="limit_1_low" value="-0.26" />
<xacro:property name="limit_2_up" value="0.97" />
<xacro:property name="limit_2_low" value="-0.274" />
<xacro:property name="limit_3_up" value="0.90" />
<xacro:property name="limit_3_low" value=" -0.27" />

<xacro:property name="limit_0_t_up" value="1.496" />
<xacro:property name="limit_0_t_low" value="0.363" />
<xacro:property name="limit_1_t_up" value="1.263" />
<xacro:property name="limit_1_t_low" value="-0.205" />
<xacro:property name="limit_2_t_up" value="1.27" />
<xacro:property name="limit_2_t_low" value="-0.12" />
<xacro:property name="limit_3_t_up" value="1.75" />
<xacro:property name="limit_3_t_low" value="-0.28" />

<!-- ============================================================================= -->
<!-- ============================================================================= -->
<!-- ============================================================================= -->

<!-- THUMB MACRO -->
<xacro:macro name="thumb" params="side asset_prefix finger_num fingertip sphere_fingertip_coll offset_origin_x offset_origin_y offset_origin_z finger_angle_r finger_angle_p finger_angle_y fingertip_angle_r fingertip_angle_y">

	<xacro:if value="${side == 'left'}">
		<xacro:property name="thumb_base_mesh" value="${asset_prefix}/meshes/link_12.0_left.STL" />
		<xacro:property name="thumb_base_coll_y" value="-0.009" />
		<xacro:property name="thumb_base_jnt_roll" value="1" />
		<xacro:property name="thumb_yaw_jnt_yaw" value="-1" />
		<xacro:property name="thumb_yaw_jnt_y" value="-0.005" />
	</xacro:if>
	<xacro:unless value="${side == 'left'}">
		<xacro:property name="thumb_base_mesh" value="${asset_prefix}/meshes/link_12.0_right.STL" />
		<xacro:property name="thumb_base_coll_y" value="0.009" />
		<xacro:property name="thumb_base_jnt_roll" value="-1" />
		<xacro:property name="thumb_yaw_jnt_yaw" value="1" />
		<xacro:property name="thumb_yaw_jnt_y" value="0.005" />
	</xacro:unless>

	<xacro:if value="${fingertip == fingertip_enum_base}">
		<xacro:property name="fingertip_mesh" value="${asset_prefix}/meshes/link_15.0_tip.STL" />
		<xacro:property name="fingertip_jnt_z" value="${link3_t_z-fingerTip_r}" />
	</xacro:if>
	<xacro:if value="${fingertip == fingertip_enum_digit}">
		<xacro:property name="fingertip_mesh" value="${asset_prefix}/meshes/digit.dae" />
		<xacro:property name="fingertip_jnt_z" value="0.0303" />
	</xacro:if>
	<xacro:if value="${fingertip == fingertip_enum_digit360}">
		<xacro:property name="fingertip_mesh" value="${asset_prefix}/meshes/digitv2.dae" />
		<xacro:property name="fingertip_jnt_z" value="0.0303" />
	</xacro:if>

<!-- [LINK 12] -->
	<link name="link_${finger_num*4+0}.0">

    	<visual>
			<geometry>
      			<mesh filename="${thumb_base_mesh}" />
      		</geometry>
      		<material name="black">
        		<color rgba=".2 .2 .2 1"/>
      		</material>
			<xacro:if value="${side == 'left'}">
      			<origin rpy="${180*DEG2RAD} 0 0" xyz="0 0 0"/>
			</xacro:if>
    	</visual>

    	<collision>
      		<geometry>
        		<box size="${link0_t_x} ${link0_t_y} ${link0_t_z}"/>
      		</geometry>

     		<origin rpy="0 0 0" xyz="${-0.0358/2+0.0} ${thumb_base_coll_y} ${.029/2}"/>
    	</collision>
		<inertial>
			<mass value="0.0176" />
			<origin xyz="0 0 0" rpy="0 0 0"/>
			<inertia ixx="1.89273333333e-5" ixy="7.16716e-06" ixz="5.35568e-06"
					iyy="1.43008213333e-05" iyz="6.8068e-06"
					izz="1.89273333333e-05" />
		</inertial>
	</link>

	<joint name="joint_${finger_num*4+0}$(arg joint_postfix)" type="revolute">

    	<axis xyz="${thumb_base_jnt_roll} 0 0"/>
    	<limit effort="0.35" velocity="6.283" lower="${limit_0_t_low-joint_safety_margin}" upper="${limit_0_t_up-joint_safety_margin}" />
    	<parent link="base_link"/>
    	<child link="link_${finger_num*4+0}.0"/>
    	<origin rpy="${finger_angle_r} ${finger_angle_p} ${finger_angle_y}" xyz="${offset_origin_x} ${offset_origin_y} ${offset_origin_z}"/>

	</joint>


<!-- [LINK 13] -->
	<link name="link_${finger_num*4+1}.0">
		<visual>
			<geometry>
		    	<mesh filename="${asset_prefix}/meshes/link_13.0.STL" />
		  	</geometry>

		  	<material name="black">
		  		<color rgba=".2 .2 .2 1"/>
		 	</material>
		</visual>

		<collision>
			<geometry>
		    	<box size="${links_x} ${links_y} ${link1_t_z}"/>
		  	</geometry>

		  	<origin rpy="0 0 0" xyz="0 0 ${link1_t_z/2}"/>
		</collision>

		<inertial>
			<mass value="0.0119" />
			<origin xyz="0 0 0" rpy="0 0 0"/>
			<inertia ixx="4.24250866667e-06" ixy="1.032087e-06" ixz="1.603525e-06"
					iyy="4.52362633333e-06" iyz="1.44808125e-06"
					izz="4.24250866667e-06" />
		</inertial>
	</link>

  	<joint name="joint_${finger_num*4+1}$(arg joint_postfix)" type="revolute">

    	<axis xyz="0 0 ${thumb_yaw_jnt_yaw}"/>
     	<limit effort="0.35" velocity="6.283" lower="${limit_1_t_low+joint_safety_margin}" upper="${limit_1_t_up-joint_safety_margin}" />
    	<parent link="link_${finger_num*4+0}.0"/>
    	<child link="link_${finger_num*4+1}.0"/>

    	<origin xyz="-0.027 ${thumb_yaw_jnt_y} 0.0399"/>

  	</joint>


<!-- [LINK 14] -->

	<link name="link_${finger_num*4+2}.0">
		<visual>
			<geometry>
		  		<mesh filename="${asset_prefix}/meshes/link_14.0.STL" />
			</geometry>
			<material name="black">
		  		<color rgba=".2 .2 .2 1"/>
		  	</material>
		</visual>

		<collision>
			<geometry>
		    	<box size="${links_x} ${links_y} ${link2_t_z}"/>
		  	</geometry>
		  	<origin rpy="0 0 0" xyz="0 0 ${link2_t_z/2}"/>
		</collision>
		<inertial>
			<mass value="0.038" />
			<origin xyz="0 0 0" rpy="0 0 0"/>
			<inertia ixx="4.30439933333e-05" ixy="9.57068e-06" ixz="5.1205e-06" iyy="1.44451933333e-05"
					iyz="1.342825e-05" izz="4.30439933333e-05" />
		</inertial>
	</link>

  <joint name="joint_${finger_num*4+2}$(arg joint_postfix)" type="revolute">

		<axis xyz="0 1 0"/>
		<limit effort="0.35" velocity="6.238" lower="${limit_2_t_low+joint_safety_margin}" upper="${limit_2_t_up-joint_safety_margin}" />
		<parent link="link_${finger_num*4+1}.0"/>
		<child link="link_${finger_num*4+2}.0"/>
		<origin xyz="0 0 ${link1_t_z}"/>

  </joint>


<!-- [LINK 15] -->

	<link name="link_${finger_num*4+3}.0">

    	<visual>
      		<geometry>
      				<mesh filename="${asset_prefix}/meshes/link_15.0.STL" />
        	</geometry>

    	<material name="black">
            <color rgba=".2 .2 .2 1"/>
    	</material>
    	</visual>

    	<collision>
			<geometry>
				<xacro:if value="${sphere_fingertip_coll}">
					<sphere radius="0.0001"/>
				</xacro:if>
				<xacro:unless value="${sphere_fingertip_coll}">
					<box size="${links_x} ${links_y} ${link3_t_z-fingerTip_r}"/>
				</xacro:unless>
			</geometry>
      		<origin rpy="0 0 0" xyz="0 0 ${(link3_t_z-fingerTip_r)/2}"/>
    	</collision>
		<inertial>
			<mass value="0.0388" />
			<origin xyz="0 0 0" rpy="0 0 0"/>
			<inertia ixx="3.29223173333e-05" ixy="8.042076e-06" ixz="5.2283e-06"
					iyy="1.47493026667e-5" iyz="1.1283525e-5"
					izz="3.29223173333e-05" />
		</inertial>
	</link>

	<joint name="joint_${finger_num*4+3}$(arg joint_postfix)" type="revolute">
    	<axis xyz="0 1 0"/>
     	<limit effort="0.35" velocity="6.238" lower="${limit_3_t_low+joint_safety_margin}" upper="${limit_3_t_up-joint_safety_margin}" />
    	<parent link="link_${finger_num*4+2}.0"/>
    	<child link="link_${finger_num*4+3}.0"/>
    	<origin xyz="0 0 ${link2_t_z}"/>
	</joint>

<!-- [FINGER TIP] -->

	<link name="link_${finger_num*4+3}.0_tip">
		<visual>
			<geometry>
		  		<mesh filename="${fingertip_mesh}" />
		  	</geometry>

		  	<material name="white">
		  		<color rgba=".9 .9 .9 1"/>
		  	</material>
    	</visual>

     	<collision>
			<xacro:if value="${sphere_fingertip_coll}">
				<geometry>
					<sphere radius="0.016"/>
				</geometry>
				<origin rpy="0 0 0" xyz="0.0036695246 0.0000277434 0.0124368531" />
			</xacro:if>
			<xacro:unless value="${sphere_fingertip_coll}">
				<geometry>
					<xacro:if value="${fingertip == fingertip_enum_base}">
						<sphere radius="${fingerTip_r}"/>
					</xacro:if>
					<xacro:unless value="${fingertip == fingertip_enum_base}">
						<mesh filename="${fingertip_mesh}" />
					</xacro:unless>
				</geometry>
				<origin rpy="0 0 0" xyz="0 0 0"/>
			</xacro:unless>
    	</collision>

	</link>

  	<joint name="joint_${finger_num*4+3}_tip" type="fixed">
    	<parent link="link_${finger_num*4+3}.0"/>
    	<child link="link_${finger_num*4+3}.0_tip"/>
    	<origin rpy="${fingertip_angle_r} 0 ${fingertip_angle_y}" xyz="0 0 ${fingertip_jnt_z}"/>
  	</joint>

</xacro:macro>

<!-- END THUMB MACRO -->

<!-- THREE FINGER MACRO -->
<xacro:macro name="finger" params="asset_prefix finger_num fingertip sphere_fingertip_coll offset_origin_x offset_origin_y offset_origin_z finger_angle_r fingertip_angle_r fingertip_angle_y">

	<xacro:if value="${fingertip == fingertip_enum_base}">
		<xacro:property name="fingertip_mesh" value="${asset_prefix}/meshes/link_3.0_tip.STL" />
		<xacro:property name="fingertip_jnt_z" value="${link3_z-fingerTip_r}" />
	</xacro:if>
	<xacro:if value="${fingertip == fingertip_enum_digit}">
		<xacro:property name="fingertip_mesh" value="${asset_prefix}/meshes/digit.dae" />
		<xacro:property name="fingertip_jnt_z" value="0.0147" />
	</xacro:if>
	<xacro:if value="${fingertip == fingertip_enum_digit360}">
		<xacro:property name="fingertip_mesh" value="${asset_prefix}/meshes/digitv2.dae" />
		<xacro:property name="fingertip_jnt_z" value="0.0147" />
	</xacro:if>

<!-- [LINK 0, 4, 8] -->

	<link name="link_${finger_num*4+0}.0">
    	<visual>
    		<geometry>
      			<mesh filename="${asset_prefix}/meshes/link_0.0.STL" />
      		</geometry>
      		<material name="black">
		  		<color rgba=".2 .2 .2 1"/>
      		</material>
    	</visual>

    	<collision>
      		<geometry>
        		<box size="${links_x} ${links_y} ${link0_z}"/>
      		</geometry>
      		<origin rpy="0 0 0" xyz="0 0 ${link0_z/2}"/>
    	</collision>
		<inertial>
			<mass value="0.0119" />
			<origin xyz="0 0 0" rpy="0 0 0"/>
			<inertia ixx="1.01666658333e-06" ixy="0.0" ixz="0.0"
					iyy="6.47677333333e-07" iyz="0.0"
					izz="1.01666658333e-06" />
		</inertial>
	</link>

  	<joint name="joint_${finger_num*4+0}$(arg joint_postfix)" type="revolute">
    	<axis xyz="0 0 1"/>
    	<limit effort="0.35" velocity="6.283" lower="${limit_0_low+joint_safety_margin}" upper="${limit_0_up-joint_safety_margin}" />
    	<parent link="base_link"/>
    	<child link="link_${finger_num*4+0}.0"/>
    	<origin rpy="${finger_angle_r} 0 0" xyz="${offset_origin_x} ${offset_origin_y} ${offset_origin_z}"/>
  	</joint>


<!-- [LINK 1, 5, 9] -->

	<link name="link_${finger_num*4+1}.0">
    	<visual>
      		<geometry>
      			<mesh filename="${asset_prefix}/meshes/link_1.0.STL" />
      		</geometry>
      		<material name="black">
		  		<color rgba=".2 .2 .2 1"/>
		  	</material>
    	</visual>

    	<collision>
      		<geometry>
        		<box size="${links_x} ${links_y} ${link1_z}"/>
      		</geometry>
	  		<origin rpy="0 0 0" xyz="0 0 ${link1_z/2}"/>
    	</collision>
		<inertial>
			<mass value="0.065" />
			<origin xyz="0 0 0" rpy="0 0 0"/>
			<inertia ixx="7.95654166667e-05" ixy="1.7199e-05" ixz="8.75875e-06"
					iyy="2.47088833333e-05" iyz="2.413125e-05"
					izz="7.95654166667e-05" />
		</inertial>
  	</link>

  	<joint name="joint_${finger_num*4+1}$(arg joint_postfix)" type="revolute">
  		<limit effort="0.35" velocity="6.283" lower="${limit_1_low+joint_safety_margin}" upper="${limit_1_up-joint_safety_margin}" />
    	<axis xyz="0 1 0"/>
    	<parent link="link_${finger_num*4+0}.0"/>
    	<child link="link_${finger_num*4+1}.0"/>
    	<origin xyz="0 0 ${link0_z}"/>
  	</joint>


<!-- [LINK 2, 6, 10]-->

	<link name="link_${finger_num*4+2}.0">
    	<visual>
      		<geometry>
      			<mesh filename="${asset_prefix}/meshes/link_2.0.STL" />
      		</geometry>
      		<material name="black">
		  		<color rgba=".2 .2 .2 1"/>
            </material>
    	</visual>

    	<collision>
      		<geometry>
        		<box size="${links_x} ${links_y} ${link2_z}"/>
      		</geometry>
      		<origin rpy="0 0 0" xyz="0 0 ${link2_z/2}"/>
    	</collision>
		<inertial>
			<mass value="0.0355" />
			<origin xyz="0 0 0" rpy="0 0 0"/>
			<inertia ixx="2.63979183333e-05" ixy="6.67968e-06" ixz="4.783625e-06"
					iyy="1.34948516667e-05" iyz="9.372e-06"
					izz="2.63979183333e-05" />
		</inertial>
  	</link>

  	<joint name="joint_${finger_num*4+2}$(arg joint_postfix)" type="revolute">
    	<axis xyz="0 1 0"/>
    	<limit effort="0.35" velocity="6.283" lower="${limit_2_low+joint_safety_margin}" upper="${limit_2_up-joint_safety_margin}" />
    	<parent link="link_${finger_num*4+1}.0"/>
    	<child link="link_${finger_num*4+2}.0"/>
    	<origin xyz="0 0 ${link1_z}"/>
  	</joint>


<!-- [LINK 3, 7, 11] -->

	<link name="link_${finger_num*4+3}.0">
    	<visual>
      		<geometry>
      			<mesh filename="${asset_prefix}/meshes/link_3.0.STL" />
        	</geometry>
      		<material name="black">
		  		<color rgba=".2 .2 .2 1"/>
	        </material>
    	</visual>

    	<collision>
			<geometry>
				<xacro:if value="${sphere_fingertip_coll}">
					<sphere radius="0.0001"/>
				</xacro:if>
				<xacro:unless value="${sphere_fingertip_coll}">
					<box size="${links_x} ${links_y} ${link3_z-fingerTip_r}"/>
				</xacro:unless>
			</geometry>
      		<origin rpy="0 0 0" xyz="0 0 ${(link3_z-fingerTip_r)/2}"/>
    	</collision>
		<inertial>
			<mass value="0.0096" />
			<origin xyz="0 0 0" rpy="0 0 0"/>
			<inertia ixx="4.701248e-06" ixy="1.255968e-06" ixz="1.2936e-06"
					iyy="3.649312e-06" iyz="1.7622e-06"
					izz="4.701248e-06" />
		</inertial>
  	</link>

  	<joint name="joint_${finger_num*4+3}$(arg joint_postfix)" type="revolute">
    	<axis xyz="0 1 0"/>
    	<limit effort="0.35" velocity="6.283" lower="${limit_3_low+joint_safety_margin}" upper="${limit_3_up-joint_safety_margin}" />
    	<parent link="link_${finger_num*4+2}.0"/>
    	<child link="link_${finger_num*4+3}.0"/>
    	<origin xyz="0 0 ${link2_z}"/>
  	</joint>

<!-- [FINGER TIP] -->

	<link name="link_${finger_num*4+3}.0_tip">
   		<visual>
      		<geometry>
      			<mesh filename="${fingertip_mesh}" />
        	</geometry>
		  	<material name="white">
        		<color rgba=".9 .9 .9 1"/>
      		</material>
    	</visual>

     	<collision>
			<xacro:if value="${sphere_fingertip_coll}">
				<geometry>
					<sphere radius="0.016"/>
				</geometry>
				<origin rpy="0 0 0" xyz="0.0036695246 0.0000277434 0.0124368531" />
			</xacro:if>
			<xacro:unless value="${sphere_fingertip_coll}">
				<geometry>
					<xacro:if value="${fingertip == fingertip_enum_base}">
						<sphere radius="${fingerTip_r}"/>
					</xacro:if>
					<xacro:unless value="${fingertip == fingertip_enum_base}">
						<mesh filename="${fingertip_mesh}" />
					</xacro:unless>
				</geometry>
			</xacro:unless>
    	</collision>
		<inertial>
			<mass value="0.0168" />
			<origin xyz="0 0 0" rpy="0 0 0"/>
			<inertia ixx="9.68e-07" ixy="0" ixz="0"
					iyy="9.68e-07" iyz="0"
					izz="9.68e-07" />
		</inertial>

  		</link>
		<joint name="joint_${finger_num*4+3}_tip" type="fixed">
    		<parent link="link_${finger_num*4+3}.0"/>
    		<child link="link_${finger_num*4+3}.0_tip"/>
    		<origin rpy="${fingertip_angle_r} 0 ${fingertip_angle_y}" xyz="0 0 ${fingertip_jnt_z}"/>
  		</joint>

</xacro:macro>
<!-- [[END]] THREE FINGER MACRO -->

<!-- ============================================================================= -->
<!-- ============================================================================= -->
<!-- ============================================================================= -->

</robot>
